# ── TMDB (required) ─────────────────────────────────────
# Get your free Read Access Token at: themoviedb.org/settings/api
TMDB_BEARER_TOKEN=your_tmdb_read_access_token_here

# ── TRAKT (required for watchlist/history sync) ──────────
# Create a free app at: trakt.tv/oauth/applications/new
# Set the redirect URI to: http://127.0.0.1:7000/auth/trakt/callback
TRAKT_CLIENT_ID=your_trakt_client_id_here
TRAKT_CLIENT_SECRET=your_trakt_client_secret_here

# ── SERVER ────────────────────────────────────────────────
PORT=7000
# When deploying, set this to your public URL
# e.g. PUBLIC_URL=https://your-app.railway.app
PUBLIC_URL=http://127.0.0.1:7000

# ── CACHE TTL (seconds) ───────────────────────────────────
CACHE_TTL_CATALOG=300
CACHE_TTL_META=600
CACHE_TTL_HISTORY=120
